# Neon PostgreSQL runtime connection. Use the pooled endpoint in serverless deployments.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DATABASE?sslmode=verify-full"

# Generate each secret independently, for example: openssl rand -base64 32
AUTH_SECRET=""
CRON_SECRET=""
INGEST_TOKEN=""

# Required only while creating the first administrator. Remove it afterwards.
ADMIN_BOOTSTRAP_TOKEN=""

# Optional dedicated HMAC key for authentication rate limits.
# Falls back to AUTH_SECRET when omitted.
AUTH_RATE_LIMIT_SECRET=""

# Required for every registration, including the first administrator.
INVITE_CODE=""

# Optional select.live integration.
SELECT_LIVE_EMAIL=""
SELECT_LIVE_PWD=""
SELECT_LIVE_SYSTEM=""

# Optional WhatsApp bot integration.
# Get these from Meta WhatsApp Cloud API: https://developers.facebook.com/apps
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN=""

# Optional Tapo smart plug integration.
TAPO_EMAIL=""
TAPO_PASSWORD=""
